# =============================================================================
# CalorieMaster — environment configuration
# =============================================================================
# Copy this file to `.env` at the project root (which is .gitignored).
# The same `.env` is read by `npm run dev` (tsx watch) and by the Docker
# container (compose forwards the relevant vars).
#
# All API keys live on the SERVER. The browser never holds any key — it
# only talks to /api/* on its own origin and the local Fastify process
# injects the keys when calling Qwen / 薄荷.
# =============================================================================

NODE_ENV=development
PORT=3000
HOST=127.0.0.1

# PostgreSQL — used by Fastify + Drizzle.
DATABASE_URL=postgresql://caloriemaster:caloriemaster@localhost:5432/caloriemaster

# Single page origin. Used for CSRF Origin/Referer checks AND to scope
# the session cookie. In development the SPA is served by Vite on 5173,
# so APP_ORIGIN must be that. In production, set it to the public URL.
APP_ORIGIN=http://localhost:5173

# When behind Caddy / Nginx / Cloudflare, set to true so Fastify
# honours X-Forwarded-Proto / X-Forwarded-For (req.ip, req.protocol).
TRUST_PROXY=false

# Cookie / session
SESSION_COOKIE_NAME=caloriemaster_session
SESSION_TTL_DAYS=30

# Qwen-VL (百炼) — required for /api/recognize-food.
QWEN_API_KEY=
QWEN_MODEL=qwen3-vl-flash
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 薄荷 (Boohee) — optional, used for nutrition enrichment.
BOOHEE_API_KEY=
BOOHEE_API_URL=https://api.boohee.com

# AI rate limits. In-memory for single-instance deployments; see README
# for the multi-instance trade-off.
AI_RATE_LIMIT_PER_MINUTE=5
AI_DAILY_QUOTA=100
AUTH_RATE_LIMIT_PER_MINUTE=10
AI_IP_RATE_LIMIT_PER_MINUTE=20

# Auto-apply Drizzle migrations on startup. Off in production, on in
# dev / test. Production deployments should run `npm run db:migrate`
# explicitly as a separate step.
AUTO_MIGRATE=false
