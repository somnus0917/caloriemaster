# Copy this file to .env at the project root and fill in your keys.
# .env is in .gitignore, so it will never be committed to GitHub.
#
# The dev server (`npm run dev`) and the production preview server
# (`npm run build && npm run preview`) BOTH read this file. The browser
# never sees the raw keys — it only talks to /api/qwen and /api/boohee,
# which the local server proxies with the keys attached.

# Qwen-VL (百炼) API key — required for AI food recognition.
QWEN_API_KEY=sk-xxxxxxxx

# Endpoint of an OpenAI-compatible Qwen-VL chat completions API.
# Override this if you proxy Qwen through your own backend.
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# Qwen-VL model name to call.
QWEN_MODEL=qwen3-vl-flash

# 薄荷 (boohee) X-Api-Key — optional but recommended for nutrition enrichment.
BOOHEE_API_KEY=

# Default daily calorie target / limit, used until the user changes them.
VITE_DAILY_GOAL=2000
VITE_DAILY_LIMIT=2300

# Port for the production preview server (`npm run preview`).
PORT=8000

# Comma-separated list of allowed Origin headers for the preview server.
# Local development defaults are filled in automatically.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ⚠️ This file is for personal local development only.
# If you ever deploy the proxy to a server anyone on the internet can reach,
# add authentication (the proxy will burn your keys for any visitor).
